<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="700.0" prefWidth="1200.0"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.finalproject2026.Controller.SessionsController">
    <children>
        <!-- Menu Bar -->
        <HBox prefHeight="50.0" spacing="10.0"
              style="-fx-padding: 10px; -fx-background-color: #333;">
            <children>
                <Button onAction="#handleDashboardMenu" prefHeight="30.0"
                        prefWidth="120.0" style="-fx-background-color: #555; -fx-text-fill: white;"
                        text="Dashboard" />
                <Button onAction="#handleDevicesMenu" prefHeight="30.0"
                        prefWidth="120.0" style="-fx-background-color: #555; -fx-text-fill: white;"
                        text="Devices" />
                <Button onAction="#handleSessionsMenu" prefHeight="30.0"
                        prefWidth="120.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"
                        text="Sessions" />
            </children>
        </HBox>

        <!-- Toolbar -->
        <ToolBar prefHeight="50.0" style="-fx-padding: 10px;">
            <items>
                <Button onAction="#handleNewSession" mnemonicParsing="false"
                        style="-fx-background-color: #2196F3; -fx-text-fill: white;"
                        text="New Session" />
                <Separator orientation="VERTICAL" />
                <Label text="User:" />
                <ComboBox fx:id="userComboBox" prefWidth="150.0" promptText="Select User" />
                <Label text="Workstation:" />
                <ComboBox fx:id="workstationComboBox" prefWidth="150.0"
                          promptText="Select PC" />
                <Separator orientation="VERTICAL" />
                <TextField fx:id="searchField" prefWidth="200.0" promptText="Search by Session ID" />
                <Button onAction="#handleSearch" text="Search" />
                <Button onAction="#handleRefresh" text="Refresh" />
            </items>
        </ToolBar>

        <!-- Active Sessions Table -->
        <Label alignment="CENTER" prefHeight="40.0" style="-fx-font-size: 24px; -fx-font-weight: bold;"
               text="Active Sessions" />

        <TableView fx:id="activeSessionsTable" prefHeight="550.0" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="sessionIdCol" prefWidth="100.0" text="Session ID" />
                <TableColumn fx:id="workstationCol" prefWidth="120.0" text="Workstation" />
                <TableColumn fx:id="userCol" prefWidth="150.0" text="User" />
                <TableColumn fx:id="startTimeCol" prefWidth="120.0" text="Start Time" />
                <TableColumn fx:id="durationCol" prefWidth="100.0" text="Duration" />
                <TableColumn fx:id="costCol" prefWidth="100.0" text="Current Cost" />
            </columns>
            <contextMenu>
                <ContextMenu>
                    <items>
                        <MenuItem onAction="#handleEndSession" text="End Session" />
                    </items>
                </ContextMenu>
            </contextMenu>
        </TableView>

        <!-- Status Bar -->
        <HBox prefHeight="30.0" style="-fx-padding: 5px; -fx-background-color: #f0f0f0;">
            <children>
                <Label fx:id="statusLabel" text="Ready" />
            </children>
        </HBox>
    </children>
</VBox>